# ============================================
# Swarmy Skillz — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- MiroFish / NVIDIA LLM Backend (Required) ---
MIROFISH_URL=http://localhost:5001
NVIDIA_API_KEY=nvapi-your-nvidia-api-key                          # REQUIRED — get free from https://build.nvidia.com
LLM_API_KEY=${NVIDIA_API_KEY}                                     # REQUIRED — same as NVIDIA_API_KEY
LLM_BASE_URL=https://integrate.api.nvidia.com/v1                  # REQUIRED — NVIDIA inference endpoint
LLM_MODEL_NAME=meta/llama-3.3-70b-instruct                       # REQUIRED — default model

# --- Zep Cloud (Required — free tier: 1000 credits/month) ---
ZEP_API_KEY=z_your-zep-api-key                                   # REQUIRED — get free from https://app.getzep.com

# --- Data Collection (Optional) ---
COINGECKO_API_KEY=                                                # Optional — increases CoinGecko rate limit
NEWS_API_KEY=                                                     # Optional — enables news headlines in seed data (https://newsapi.org)
